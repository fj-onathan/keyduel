APP_ENV=development

# ─── Quick start ────────────────────────────────────────────────────
# Copy this file to .env, fill in GitHub OAuth values, then run:
#   make dev-up          # starts everything (Postgres, Redis, API, Race Engine, Bot Runner, Client)
#   make migrate-up      # apply database migrations (first time only)
#   make seed-snippets   # seed code snippets (first time only)
#
# Or start services individually:
#   make infra-up        # Postgres + Redis only
#   make server-api      # Go API (requires local Go)
#   make server-race     # Go Race Engine (requires local Go)
#   make client-dev      # React dev server (requires local Node)

# App ports
API_PORT=8080
RACE_ENGINE_PORT=8081
CLIENT_PORT=5173

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=typing_game
POSTGRES_USER=typing_game
POSTGRES_PASSWORD=typing_game
DATABASE_URL=postgres://typing_game:typing_game@localhost:5432/typing_game?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback

# Sessions
SESSION_SECRET=replace_me_with_random_32_bytes

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend
FRONTEND_URL=http://localhost:5173

# Frontend
VITE_APP_NAME=KeyDuel
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_BASE_URL=ws://localhost:8081/ws

# Bot Runner
BOT_ENABLED=false
BOT_CONCURRENCY=5
BOT_MIN_CONCURRENCY=3
BOT_MAX_CONCURRENCY=9
BOT_RACE_INTERVAL_SECONDS=600
BOT_WS_URL=ws://localhost:8081/ws
BOT_API_URL=http://localhost:8081
